# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/jobpilot?schema=public"

# ─── Clerk Authentication ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── AI — Gemini ──────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─── File Uploads — UploadThing ───────────────────────────────────
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=...

# ─── Email — Resend ───────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="JobPilot <noreply@jobpilot.dev>"

# ─── Job APIs ─────────────────────────────────────────────────────
# Adzuna (free tier: 1k reqs/month)
ADZUNA_APP_ID=...
ADZUNA_APP_KEY=...

# JSearch via RapidAPI (10 free searches/month)
JSEARCH_API_KEY=...

# Remotive (free, no key needed but set base URL)
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

# ─── Redis — Upstash (rate limiting + caching) ────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=JobPilot
NODE_ENV=development

# ─── Playwright (optional, for auto-apply) ────────────────────────
PLAYWRIGHT_HEADLESS=true
